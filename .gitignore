# gitignore template for LangChain products, e.g., LangGraph, LangSmith
# website: https://www.langchain.com/
# website: https://www.langchain.com/langgraph

# LangGraph
.langgraph_api/

# Mitchell's common ignores
# --- General / OS ---
.DS_Store
Thumbs.db
.env
*.log
*.swp
*playground*

# --- Node.js ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.npm/
.eslintcache
.stylelintcache

# --- Node.js Build Outputs ---
dist/
build/
.next/
.vuepress/dist
.cache/

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
.venv/
pip-log.txt
pip-delete-this-directory.txt
.tox/
.nox/
.coverage
.cache
nosetests.xml
coverage.xml
*.cover
*.pyo
.pytest_cache/

# --- IDEs & Editors ---
.vscode/
.idea/
*.code-workspace
*.sublime-project
*.sublime-workspace

# --- Evals ---
evals/results/*.json
evals/results/*.md
